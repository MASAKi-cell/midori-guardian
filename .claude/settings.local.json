{
  "permissions": {
    "allow": [
      "Bash(gh issue *)",
      "Bash(gh project *)",
      "Bash(jq *)",
      "Bash(uv run*python3 .claude/skills/*)",
      "WebSearch",
      "WebFetch",
      "Write",
      "Read(~/.zshrc)"
    ],
    "deny": [
      "Bash(gh repo delete*)",
      "Bash(gh repo archive*)",
      "Bash(gh pr close*)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/.env)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [".claude/**"],
      "denyRead": ["~/.ssh/**"]
    },
    "network": {
      "deniedDomains": ["169.254.169.254", "metadata.google.internal"],
      "allowLocalBinding": true
    }
  }
}
